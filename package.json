{
  "name": "articler",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "e2e": "playwright test --pass-with-no-tests",
    "e2e:docker": "docker compose --profile e2e run --rm --build e2e"
  },
  "dependencies": {
    "argon2": "^0.44.0",
    "drizzle-orm": "^0.45.2",
    "next": "15.3.1",
    "next-auth": "5.0.0-beta.31",
    "postgres": "^3.4.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.4.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2"
    ]
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.59.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "15.3.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "postcss": "^8",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
